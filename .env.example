# ── XENITH · Шаблон переменных окружения ────────────────────────────────────
# Скопируй этот файл в .env и заполни нужные ключи.
# Ollama работает без ключей — просто запусти `ollama serve`.

# Ollama (локально, по умолчанию)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIza...

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# OpenRouter (200+ моделей)
OPENROUTER_API_KEY=sk-or-...

# Mistral
MISTRAL_API_KEY=...

# Groq
GROQ_API_KEY=gsk_...

# xAI (Grok)
XAI_API_KEY=xai-...
